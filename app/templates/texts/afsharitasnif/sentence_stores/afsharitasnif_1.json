{"sentences": {"1": {"source": "\u0632 \u062c\u0647\u0627\u0646 \u062f\u0644 \u0628\u0631\u06a9\u0646\u062f\u0645 \u062a\u0627 \u0634\u0648\u0631\u06cc \u067e\u06cc\u062f\u0627 \u06a9\u0631\u062f\u0645\n\u062a\u0648 \u0633\u06cc\u0647 \u06af\u06cc\u0633\u0648 \u06a9\u0631\u062f\u06cc \u0686\u0648\u0646 \u0645\u062c\u0646\u0648\u0646 \u0635\u062d\u0631\u0627 \u06af\u0631\u062f\u0645", "translation": "\nFrom the world I tore my heart until I found passion\nYou with your black tresses made me wander the desert like Majnun\n"}, "2": {"source": "\u0632 \u062a\u0648 \u0646\u0648\u0634\u06cc\u0646 \u0644\u0628 \u0628\u0627\u0634\u062f \u0647\u0645 \u062f\u0631\u0645\u0627\u0646 \u0648 \u0647\u0645 \u062f\u0631\u062f\u0645\n\u062f\u0644\u0645 \u0627\u0632 \u062e\u0648\u0646 \u0686\u0648\u0646 \u0645\u06cc\u0646\u0627 \u0644\u0628\u0631\u06cc\u0632 \u0648 \u0645\u0646 \u062e\u0627\u0645\u0648\u0634\u0645 ", "translation": "\nFrom your sweet lips comes both my cure and my pain\nMy heart is full of blood like a wine glass, yet I remain silent\n"}, "3": {"source": "\u0634\u0628 \u0647\u062c\u0631\u0627\u0646 \u062c\u0627\u06cc \u0645\u06cc \u062e\u0648\u0646\u0627\u0628 \u062f\u0644 \u0645\u06cc \u0646\u0648\u0634\u0645\n\u0632 \u062e\u06cc\u0627\u0644\u062a \u0628\u0631\u062e\u06cc\u0632\u062f \u0628\u0648\u06cc \u06af\u0644 \u0627\u0632 \u0622\u063a\u0648\u0634\u0645", "translation": "\nOn the night of separation, instead of wine I drink the blood of my heart\nFrom your imagination, the scent of roses rises from my embrace\n"}, "4": {"source": "\u062a\u0648 \u0633\u06cc\u0647 \u0686\u0634\u0645 \u0627\u0632 \u0686\u0634\u0645\u0645 \u062a\u0627 \u062f\u0648\u0631\u06cc \u0645\u0646 \u0628\u06cc\u0645\u0627\u0631\u0645\n\u062a\u0648 \u0633\u06cc\u0647 \u06af\u06cc\u0633\u0648 \u0647\u0631 \u0634\u0628 \u062f\u0631 \u062e\u0648\u0627\u0628 \u0648 \u0645\u0646 \u0628\u06cc\u062f\u0627\u0631\u0645", "translation": "\nYou black-eyed one, when you are far from my sight, I am sick\nYou black-haired one, every night you are in my dreams while I remain awake\n"}, "5": {"source": "\u062a\u0648 \u0644\u0628 \u0645\u06cc\u06af\u0648\u0646 \u062f\u0627\u0631\u06cc \u0645\u0646 \u0627\u0634\u06a9 \u06af\u0644\u06af\u0648\u0646 \u062f\u0627\u0631\u0645\n\u0632 \u062a\u0648 \u062f\u0644 \u06af\u0631 \u0628\u0631\u06af\u06cc\u0631\u0645 \u0627\u0632 \u063a\u0645 \u062f\u06cc\u06af\u0631 \u0645\u06cc \u0645\u06cc\u0631\u0645", "translation": "\nYou have wine-colored lips while I have rosy tears\nIf I take my heart from you, I will die from other sorrows\n"}, "6": {"source": "\u0628\u0647 \u062e\u062f\u0627 \u062f\u0648\u0631 \u0627\u0632 \u0631\u0648\u06cc\u062a \u0627\u0632 \u062c\u0627\u0646 \u0634\u06cc\u0631\u06cc\u0646 \u0633\u06cc\u0631\u0645", "translation": "\nBy God, away from your face, I am weary of my sweet life\n"}}, "wordMap": {"\u0632fb84b7b5-7f49-4075-8711-657e3aa7a21a": 1, "\u062c\u0647\u0627\u06460cb09b39-ffdd-4645-bd5e-7af84722cede": 1, "\u062f\u06447eda12ff-69fd-423e-ab8d-83b18e1320a6": 1, "\u0628\u0631\u06a9\u0646\u062f\u064503534867-fb94-42ca-b927-ebf9f8391b60": 1, "\u062a\u06270a64d8df-96f7-4363-bbd2-5c5ea79f8110": 1, "\u0634\u0648\u0631\u06ccf665f1de-c998-43c5-82b2-e4acaf02405c": 1, "\u067e\u06cc\u062f\u062733c26fb3-c8f1-4c8a-8440-21a31c98153d": 1, "\u06a9\u0631\u062f\u0645f6f43008-d51c-4ab1-9dfc-f982f69b84ad": 1, "\u062a\u064847181b08-1337-4134-832e-355c9c4055e8": 1, "\u0633\u06cc\u0647d8d9af73-a669-4e13-93fe-ecc95830a93f": 1, "\u06af\u06cc\u0633\u06480a3bf0fb-d430-43d4-bbbb-a8c8c18b5011": 1, "\u06a9\u0631\u062f\u06cc028c9542-95d9-4b1f-bfb8-f320712997f7": 1, "\u0686\u0648\u0646395e249a-eb11-420d-b527-7539db6fe5f2": 1, "\u0645\u062c\u0646\u0648\u0646cb31e8c4-cb6e-4f3a-a734-89d839caff6d": 1, "\u0635\u062d\u0631\u062794bcee42-93d1-4547-a6d2-a12466d507bc": 1, "\u06af\u0631\u062f\u06450f8413da-5d24-4d3a-9bd9-6ca96138807f": 1, "\u063270b348e9-714b-44d0-adcc-9cbb11b25a69": 2, "\u062a\u06484294e42e-545a-44fa-b85e-67f0eff5dfb2": 2, "\u064